{
  "name": "ancestor-tablet-search",
  "version": "0.1.0",
  "description": "Offline ancestor tablet search desktop app",
  "main": "dist/main/main.js",
  "author": "Ang Kongsi",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "postinstall": "electron-builder install-app-deps",
    "build:electron": "tsc -p tsconfig.electron.json",
    "dev": "npm run build:electron && concurrently \"vite --host 127.0.0.1 --port 5173 --strictPort\" \"wait-on http://127.0.0.1:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "build": "npm run typecheck && vite build && npm run build:electron",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.electron.json --noEmit",
    "package": "npm run build && electron-builder --win nsis portable --x64 && electron-builder install-app-deps --arch=arm64",
    "build:web": "tsc --noEmit && vite build --config vite.config.web.ts",
    "package:web": "npm run build:web && node scripts/package-web.mjs",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.4",
    "adm-zip": "^0.5.17",
    "better-sqlite3": "^12.4.1",
    "jszip": "^3.10.1",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "sql.js": "^1.14.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.6.0",
    "@types/react": "^19.1.16",
    "@types/react-dom": "^19.1.9",
    "@types/sql.js": "^1.4.11",
    "concurrently": "^9.2.1",
    "cross-env": "^10.0.0",
    "electron": "^38.2.0",
    "electron-builder": "^26.0.12",
    "typescript": "^5.9.3",
    "vite": "^7.1.7",
    "vite-plugin-singlefile": "^2.3.3",
    "wait-on": "^9.0.1"
  },
  "build": {
    "appId": "com.angkongsi.ancestorsearch",
    "productName": "神主牌搜寻系统",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "**/*.node"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    }
  }
}
